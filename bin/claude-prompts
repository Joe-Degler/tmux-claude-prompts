#!/usr/bin/env bash
# claude-prompts — dispatcher CLI for tmux-claude-prompts.
# Subcommands: open, ingest, pin, scope, query, insert, version, help.

set -euo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../scripts" && pwd)"
VERSION="0.1.0"

usage() {
  cat >&2 <<'EOF'
claude-prompts — Claude Prompt Browser

Usage:
  claude-prompts open                        Launch popup (tmux) or standalone fzf
  claude-prompts ingest [--force]            Incremental (or full) re-ingest from history.jsonl
  claude-prompts pin <id>                    Toggle pin on a prompt row
  claude-prompts scope <toggle|get|set <path>>  Manage scope (everywhere vs project)
  claude-prompts case  <toggle|get|set <mode>>  Manage case sensitivity (insensitive | sensitive)
  claude-prompts query <q>                   Emit raw fzf rows for query (debug)
  claude-prompts insert <paste|paste-literal|copy> <id>  Apply insert action
  claude-prompts group  <list|create <name>|delete <id>|rename <id> <name>>  Manage groups
  claude-prompts label  <id> [<text>]        Set/clear a prompt's short label (≤60 chars)
  claude-prompts sessions-ingest [--force]   Incremental (or full) session-transcript ingest
  claude-prompts sessions-query <q>          Emit raw session-mode fzf rows (debug)
  claude-prompts version                     Print version
  claude-prompts help                        Show this message

Popup keymap:
  Enter      Insert resolved prompt into originating pane
  Ctrl-L     Insert literal (markers unresolved)
  Ctrl-O     Copy resolved prompt to clipboard
  Ctrl-P     Toggle pin on focused row
  Ctrl-G     Open group picker (select or create)
  Ctrl-A     Row actions (group-add · label · delete)
  Ctrl-S     Toggle scope (Everywhere <-> Project)
  Shift-←/→  Cycle through all scopes (Everywhere + every project, by recency)
  Ctrl-T     Toggle case sensitivity (Aa chip dim = insensitive, cyan = sensitive)
  Ctrl-/     Toggle similar mode (semantic neighbors of focused row;
             query string further refines via lexical AND-filter)
  Ctrl-E     Toggle session-search mode (search full transcripts incl. Claude's
             responses; Enter types /resume <session-id> into the pane)
  Ctrl-R     Force re-ingest from history.jsonl
  ?          Show full keymap (cheatsheet overlay in preview pane)
  Shift-↑/↓  Scroll preview by one line
  Alt-↑/↓    Scroll preview by half a page
  Ctrl-]     Cycle preview size (30% → 80% → hidden → 30%) — also hides preview
  Ctrl-Q     Close popup (preferred over Esc, which has terminal-level lag)
  Alt-Q      Close popup (alias for Ctrl-Q)
  Esc        Also closes (kept for power users; brief lag while terminal disambiguates)
EOF
}

subcmd="${1:-}"

case "$subcmd" in
  open)
    if [ -n "${TMUX:-}" ]; then
      exec "${SCRIPT_DIR}/launch.sh" "${TMUX_PANE:-}" "${PWD}"
    else
      # Standalone mode: run fzf directly in this terminal; inserts fall back to clipboard
      export ORIG_PANE=""
      export ORIG_PATH="${PWD}"
      export CP_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
      exec "${SCRIPT_DIR}/popup.sh"
    fi
    ;;

  ingest)
    shift
    exec "${SCRIPT_DIR}/ingest.sh" "$@"
    ;;

  pin)
    id="${2:-}"
    if [ -z "$id" ]; then
      printf 'claude-prompts pin: missing <id>\n' >&2
      usage
      exit 1
    fi
    exec "${SCRIPT_DIR}/pin.sh" "$id"
    ;;

  scope)
    shift
    exec "${SCRIPT_DIR}/scope.sh" "$@"
    ;;

  case)
    shift
    exec "${SCRIPT_DIR}/case.sh" "$@"
    ;;

  query)
    q="${2:-}"
    exec "${SCRIPT_DIR}/query.sh" "$q"
    ;;

  insert)
    action="${2:-}"
    id="${3:-}"
    if [ -z "$action" ] || [ -z "$id" ]; then
      printf 'claude-prompts insert: usage: insert <paste|paste-literal|copy> <id>\n' >&2
      usage
      exit 1
    fi
    exec "${SCRIPT_DIR}/insert.sh" "$action" "$id"
    ;;

  group)
    shift
    exec "${SCRIPT_DIR}/group_manage.sh" "$@"
    ;;

  label)
    shift
    exec "${SCRIPT_DIR}/label_set.sh" "$@"
    ;;

  sessions-ingest)
    shift
    . "${SCRIPT_DIR}/helpers.sh"
    ensure_db
    exec python3 "${SCRIPT_DIR}/ingest_sessions.py" "$@"
    ;;

  sessions-query)
    q="${2:-}"
    exec "${SCRIPT_DIR}/session_query.sh" "$q"
    ;;

  version)
    printf 'claude-prompts %s\n' "$VERSION"
    ;;

  help|-h|--help)
    usage
    exit 0
    ;;

  "")
    usage
    exit 1
    ;;

  *)
    printf 'claude-prompts: unknown subcommand: %s\n' "$subcmd" >&2
    usage
    exit 1
    ;;
esac
